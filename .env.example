# ─── Server Environment Variables ─────────────────────────────────────────────
# Copy this file to server/.env and fill in your values

# MongoDB connection string
# Get yours from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://anything_admin:kksyvxAs1vZNdGGk@cluster0.xxxxx.mongodb.net/taskmanager?retryWrites=true&w=majority

# JWT secret key — use a long random string (32+ characters)
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=a2114f40432e480b9f987bf554b1b3e8c8202ace0424111c1f9258c75372becd

# Express server port
PORT=5000

# Allowed CORS origin (your frontend URL)
# Dev: http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173


# ─── Client Environment Variables ─────────────────────────────────────────────
# Create client/.env.local for local overrides (git-ignored)

# Leave blank in dev — Vite proxy handles /api → localhost:5000
# Set in production: https://your-api.onrender.com/api
VITE_API_URL=
